{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speccompass.local/schemas/outline-discovery-data.schema.json",
  "title": "SpecCompass Outline Discovery Data",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "review_type", "interaction_mode", "artifact_path",
    "outline_maturity", "batch_id", "project", "source_snapshot",
    "business_context", "constitution_snapshot",
    "density_budget", "maps", "outline_nodes", "question_groups",
    "authorization_effect", "next_route"
  ],
  "properties": {
    "schema_version": {"const": 3},
    "review_type": {"const": "outline_discovery"},
    "interaction_mode": {"const": "discovery"},
    "artifact_path": {"type": "string", "pattern": "^specs/[^/]+/prd/review/outline-discovery-data\\.json$"},
    "outline_maturity": {"enum": ["explore", "frame"]},
    "batch_id": {"type": "string", "minLength": 1},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "feature", "current_understanding", "discovery_goal"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "feature": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"},
        "current_understanding": {"type": "string", "minLength": 1},
        "discovery_goal": {"type": "string", "minLength": 1}
      }
    },
    "source_snapshot": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    },
    "business_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_subject", "business_objects", "operations", "outcomes",
        "business_chains", "evidence_gaps"
      ],
      "properties": {
        "product_subject": {"$ref": "#/$defs/sourced_semantic"},
        "business_objects": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/business_object"}
        },
        "operations": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/business_operation"}
        },
        "outcomes": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/business_outcome"}
        },
        "business_chains": {
          "type": "array", "minItems": 1,
          "items": {"$ref": "#/$defs/business_chain"}
        },
        "evidence_gaps": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence_gap"}
        }
      }
    },
    "constitution_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "availability", "display_mode", "application_scope", "clauses"],
      "properties": {
        "source_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?![A-Za-z]:/)(?!\\.\\.?(?:/|$))(?!.*\\/\\.\\.?(?:/|$))(?!.*//)[^/]+(?:/[^/]+)*$"
        },
        "availability": {"enum": ["available", "missing"]},
        "display_mode": {"const": "read_only"},
        "application_scope": {"const": "governance_only"},
        "clauses": {
          "type": "array",
          "items": {"$ref": "#/$defs/constitution_clause"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"availability": {"const": "missing"}}},
          "then": {"properties": {"clauses": {"maxItems": 0}}}
        }
      ]
    },
    "density_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_visible_nodes_per_map", "max_depth", "max_children_per_node",
        "layer_balance_min_nodes", "max_layer_share"
      ],
      "properties": {
        "max_visible_nodes_per_map": {"const": 18},
        "max_depth": {"const": 3},
        "max_children_per_node": {"const": 4},
        "layer_balance_min_nodes": {"const": 8},
        "max_layer_share": {"const": 0.6}
      }
    },
    "maps": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/map"}
    },
    "outline_nodes": {
      "type": "array",
      "minItems": 3,
      "items": {"$ref": "#/$defs/outline_node"}
    },
    "question_groups": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/question_group"}
    },
    "authorization_effect": {"const": "none"},
    "next_route": {"const": "/sp.prd"}
  },
  "$defs": {
    "map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["map_id", "title", "summary", "map_kind", "root_node_id", "parent_map_id"],
      "properties": {
        "map_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "map_kind": {"enum": ["overview", "branch", "global_constraints"]},
        "root_node_id": {"type": "string", "minLength": 1},
        "parent_map_id": {"type": ["string", "null"]}
      }
    },
    "outline_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id", "parent_node_id", "map_id", "node_kind", "label", "summary", "source_status"
      ],
      "properties": {
        "node_id": {"type": "string", "minLength": 1},
        "parent_node_id": {"type": ["string", "null"]},
        "map_id": {"type": "string", "minLength": 1},
        "node_kind": {
          "enum": [
            "root", "goal", "role", "domain", "scope", "problem", "scenario",
            "capability", "acceptance", "risk", "constraint", "map_link"
          ]
        },
        "label": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "child_map_id": {"type": "string", "minLength": 1},
        "affected_node_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "business_chain_refs": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "constitution_clause_refs": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "source_fields": {
      "type": "object",
      "required": ["source_status", "source_refs"],
      "properties": {
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "source_refs": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "sourced_semantic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "summary", "source_status", "source_refs"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "business_object": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object_id", "label", "summary", "source_status", "source_refs"],
      "properties": {
        "object_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "business_operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "label", "summary", "object_refs", "source_status", "source_refs"],
      "properties": {
        "operation_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "object_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "business_outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_id", "label", "summary", "source_status", "source_refs"],
      "properties": {
        "outcome_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "business_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain_id", "label", "trigger_or_input", "object_refs", "operation_refs",
        "outcome_refs", "source_status", "source_refs"
      ],
      "properties": {
        "chain_id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "trigger_or_input": {"type": "string", "minLength": 1},
        "object_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "operation_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "outcome_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "source_status": {"enum": ["user", "user-confirmed", "doc", "ai-proposed", "unresolved"]},
        "source_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "evidence_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_id", "summary", "business_chain_refs"],
      "properties": {
        "gap_id": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "business_chain_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    },
    "constitution_clause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clause_id", "title", "summary", "source_anchor", "applicability_status"],
      "properties": {
        "clause_id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "source_anchor": {"type": "string", "minLength": 1},
        "applicability_status": {"enum": ["applicable", "possibly_applicable", "not_applicable"]}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source_type"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "source_type": {"type": "string", "minLength": 1},
        "anchors": {"type": "array", "items": {"type": "string"}}
      }
    },
    "question_group": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "summary", "map_id", "questions"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "title": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "map_id": {"type": "string", "minLength": 1},
        "questions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/question"}}
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "outline_node_id", "target_kind", "prompt", "context", "selection_mode",
        "candidates", "recommended_candidate_ids", "recommendation_reason",
        "allow_none_of_the_above", "free_input"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "outline_node_id": {"type": "string", "minLength": 1},
        "target_kind": {"type": "string", "minLength": 1},
        "prompt": {"type": "string", "minLength": 1},
        "context": {"type": "string", "minLength": 1},
        "selection_mode": {"const": "single"},
        "candidates": {
          "type": "array", "minItems": 2, "maxItems": 4,
          "items": {"$ref": "#/$defs/candidate"}
        },
        "recommended_candidate_ids": {
          "type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "recommendation_reason": {"type": "string", "minLength": 1},
        "allow_none_of_the_above": {"const": true},
        "free_input": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "label", "allowed_operations"],
          "properties": {
            "enabled": {"const": true},
            "label": {"type": "string", "minLength": 1},
            "allowed_operations": {
              "type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true,
              "items": {"enum": ["confirm_candidate", "add", "replace", "exclude", "context_note"]}
            }
          }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "value", "rationale", "business_chain_refs"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "value": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "business_chain_refs": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
