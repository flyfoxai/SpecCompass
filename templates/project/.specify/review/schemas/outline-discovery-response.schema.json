{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speccompass.local/schemas/outline-discovery-response.schema.json",
  "title": "SpecCompass Outline Discovery Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "format", "response_id", "review_type", "batch_id",
    "feature", "outline_maturity", "source_review_data", "authorization_effect",
    "next_route", "generated_at", "deltas"
  ],
  "properties": {
    "schema_version": {"const": 3},
    "format": {"const": "speccompass-outline-discovery-response"},
    "response_id": {"type": "string", "minLength": 1},
    "review_type": {"const": "outline_discovery"},
    "batch_id": {"type": "string", "minLength": 1},
    "feature": {"type": "string", "minLength": 1},
    "outline_maturity": {"enum": ["explore", "frame"]},
    "source_review_data": {"type": "string", "minLength": 1},
    "authorization_effect": {"const": "none"},
    "next_route": {"const": "/sp.prd"},
    "generated_at": {"type": "string", "format": "date-time"},
    "deltas": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/delta"}}
  },
  "$defs": {
    "delta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delta_id", "question_id", "outline_node_id", "target_kind", "operation", "candidate_id",
        "target_id", "value", "source_tag", "none_of_the_above",
        "supersedes_delta_id"
      ],
      "properties": {
        "delta_id": {"type": "string", "minLength": 1},
        "question_id": {"type": "string", "minLength": 1},
        "outline_node_id": {"type": "string", "minLength": 1},
        "target_kind": {"type": "string", "minLength": 1},
        "operation": {"enum": ["confirm_candidate", "add", "replace", "exclude", "context_note"]},
        "candidate_id": {"type": ["string", "null"]},
        "target_id": {"type": ["string", "null"]},
        "value": {"type": "string"},
        "source_tag": {"enum": ["user", "user-confirmed"]},
        "none_of_the_above": {"type": "boolean"},
        "supersedes_delta_id": {"type": ["string", "null"]}
      },
      "allOf": [
        {
          "if": {"properties": {"operation": {"const": "confirm_candidate"}}},
          "then": {"properties": {
            "candidate_id": {"type": "string", "minLength": 1},
            "target_id": {"const": null},
            "value": {"type": "string", "minLength": 1},
            "source_tag": {"const": "user-confirmed"},
            "none_of_the_above": {"const": false}
          }}
        },
        {
          "if": {"properties": {"operation": {"const": "add"}}},
          "then": {"properties": {
            "candidate_id": {"const": null},
            "target_id": {"const": null},
            "value": {"type": "string", "minLength": 1},
            "source_tag": {"const": "user"}
          }}
        },
        {
          "if": {"properties": {"operation": {"const": "replace"}}},
          "then": {"properties": {
            "candidate_id": {"const": null},
            "target_id": {"type": "string", "minLength": 1},
            "value": {"type": "string", "minLength": 1},
            "source_tag": {"const": "user"},
            "none_of_the_above": {"const": false}
          }}
        },
        {
          "if": {"properties": {"operation": {"const": "exclude"}}},
          "then": {
            "properties": {"source_tag": {"const": "user"}, "none_of_the_above": {"const": false}},
            "oneOf": [
              {"properties": {"candidate_id": {"type": "string", "minLength": 1}, "target_id": {"const": null}}},
              {"properties": {"candidate_id": {"const": null}, "target_id": {"type": "string", "minLength": 1}}}
            ]
          }
        },
        {
          "if": {"properties": {"operation": {"const": "context_note"}}},
          "then": {"properties": {
            "candidate_id": {"const": null},
            "target_id": {"const": null},
            "value": {"type": "string", "minLength": 1},
            "source_tag": {"const": "user"},
            "none_of_the_above": {"const": false}
          }}
        }
      ]
    }
  }
}
